library(dplyr)
# Umbral de significación
threshold <- 0.05
# Proporción de positivos por cromosoma
gwas %>%
group_by(CHROM) %>%
summarise(
n_snps = n(),
n_positivos = sum(q <= threshold),
prop_positivos = n_positivos / n_snps
) %>%
arrange(desc(prop_positivos))
