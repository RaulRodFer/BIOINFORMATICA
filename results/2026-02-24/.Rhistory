# Si no has ejecutado el tercer bloque del ejercicio 1,
# la variable URL no estará definida.
platelmintos <- read.table(URLencode(URL),
header = TRUE,
colClasses = c('numeric', 'factor', 'character', 'Date', 'numeric', 'character'),
sep = '\t',
na.strings = '')
View(platelmintos)
platelmintos$genus <- sapply(
strsplit(platelmintos$scientific_name, ' '),
'[',
1)
View(platelmintos)
#| fig.width: 10
par(mar = c(8,7,1,1))
boxplot(base_count ~ genus, data = platelmintos,
las = 2, xlab = '', ylab = '', cex.axis = 0.8)
mtext('Genus', side = 1, line = 7)
mtext('Base count', side = 2, line = 5)
# Ordenar la tabla por fecha de publicación
platelmintos <- platelmintos[order(platelmintos$date), ]
# Ordenar la tabla por fecha de publicación
platelmintos <- platelmintos[order(platelmintos$date), ]
# Ordenar la tabla por fecha de publicación
platelmintos <- platelmintos[order(platelmintos$date), ]
# Ordenar la tabla por fecha de publicación
platelmintos <- platelmintos[order(platelmintos$date), ]
platelmintos <- platelmintos[order(platelmintos$date), ]
names(platelmintos)
View(platelmintos)
# Ordenar la tabla por fecha de publicación
platelmintos <- platelmintos[order(platelmintos$last_updated), ]
# Crear una nueva columna con la suma acumulada de bases
platelmintos$base_acumuladas <- cumsum(platelmintos$base_count)
# Representar la longitud acumulada a lo largo del tiempo
plot(platelmintos$last_updated, platelmintos$base_acumuladas,
type = "l",
xlab = "Fecha de publicación",
ylab = "Bases acumuladas")
View(platelmintos)
